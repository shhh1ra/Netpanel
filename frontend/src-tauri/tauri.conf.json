{
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build",
                  "devPath":  "http://127.0.0.1:1420",
                  "distDir":  "../dist",
                  "withGlobalTauri":  true
              },
    "package":  {
                    "productName":  "Netpanel",
                    "version":  "1.2.1"
                },
    "tauri":  {
                  "allowlist":  {
                                    "all":  false,
                                    "shell":  {
                                                  "all":  false,
                                                  "open":  true,
                                                  "sidecar":  true,
                                                  "scope":  [
                                                                {
                                                                    "name":  "../sidecars/netpanel-backend",
                                                                    "sidecar":  true
                                                                }
                                                            ]
                                              },
                                    "clipboard":  {
                                                      "writeText":  true
                                                  }
                                },
                  "bundle":  {
                                 "active":  true,
                                 "category":  "DeveloperTool",
                                 "externalBin":  [
                                                     "../sidecars/netpanel-backend"
                                                 ],
                                 "identifier":  "local.netpanel.app",
                                 "targets":  "all",
                                 "icon":  [
                                              "icons/32x32.png",
                                              "icons/128x128.png",
                                              "icons/128x128@2x.png",
                                              "icons/icon.ico"
                                          ]
                             },
                  "security":  {
                                   "csp":  null
                               },
                  "windows":  [
                                  {
                                      "title":  "Netpanel",
                                      "width":  1180,
                                      "height":  760,
                                      "minWidth":  940,
                                      "minHeight":  640
                                  }
                              ]
              }
}
